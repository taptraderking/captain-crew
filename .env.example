# ─── Captain Crew — Environment Variables ───────────────────────────────────
# Copy this to .env for local development
# On Render: paste these into Dashboard → Environment → Environment Variables

# ─── SESSION ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars
NODE_ENV=production

# ─── USER CREDENTIALS ────────────────────────────────────────────────────────
# Owner (remote oversight, config access)
OWNER_USERNAME=owner
OWNER_PASSWORD=change_me_owner_2024
OWNER_NAME=Rahul

# Manager (raw material purchases)
MANAGER_USERNAME=manager
MANAGER_PASSWORD=change_me_manager_2024
MANAGER_NAME=Vikram

# Accountant (sales, expenses, financial entries)
ACCOUNTANT_USERNAME=accountant
ACCOUNTANT_PASSWORD=change_me_accountant_2024
ACCOUNTANT_NAME=Priya

# ─── GOOGLE SHEETS ───────────────────────────────────────────────────────────
# 1. Create a Google Cloud project: https://console.cloud.google.com
# 2. Enable "Google Sheets API"
# 3. Create a Service Account → download JSON key
# 4. Share your Google Sheet with the service account email
# 5. Paste the ENTIRE JSON key below (one line, no line breaks)
GOOGLE_SHEET_ID=your-google-sheet-id-from-the-url
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com",...}
